# .env.example  (commit this)
# Copy to .env for local dev and adjust values

# Highest priority override (use for ngrok or any custom backend)
EXPO_PUBLIC_API_BASE=http://localhost:8000/api/v1

# CMS override (optional)
EXPO_PUBLIC_CMS_BASE=https://cms.example.com

# For physical devices on the same Wi-Fi (no protocol, just IP)
EXPO_PUBLIC_API_BASE=https://9269768a7fa5.ngrok-free.app/api/v1
